# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before running:
#
#   cp .env.example .env
#   make dev
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/clair_tax
SPRING_DATASOURCE_USERNAME=khorzeyi
SPRING_DATASOURCE_PASSWORD=

# ── Mail (SMTP / Gmail app-password) ─────────────────────────────────────────
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=khorzeyi02@gmail.com
SPRING_MAIL_PASSWORD=dzwypgpznojbmpxs

# ── Auth URLs ─────────────────────────────────────────────────────────────────
CLAIR_AUTH_FRONTEND_BASE_URL=http://localhost:3000
CLAIR_AUTH_PUBLIC_BASE_URL=http://localhost:8080

# ── AWS S3 receipt storage ────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
CLAIR_RECEIPTS_BUCKET_NAME=your-s3-bucket-name

# ── AWS SQS receipt processing queue ──────────────────────────────────────────
CLAIR_RECEIPTS_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/YOUR_ACCOUNT_ID/receipts.fifo

# ── Internal service token (shared with AI service) ───────────────────────────
CLAIR_RECEIPTS_INTERNAL_API_TOKEN=change-me-to-a-strong-random-secret

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# These are picked up by 'bun run dev' / 'bun run build' automatically.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
