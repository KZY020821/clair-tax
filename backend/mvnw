#!/bin/sh

set -eu

BASE_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
WRAPPER_PROPS="$BASE_DIR/.mvn/wrapper/maven-wrapper.properties"

if [ ! -f "$WRAPPER_PROPS" ]; then
  echo "Missing Maven wrapper properties at $WRAPPER_PROPS" >&2
  exit 1
fi

DISTRIBUTION_URL="$(grep '^distributionUrl=' "$WRAPPER_PROPS" | cut -d'=' -f2-)"
MAVEN_VERSION="$(printf '%s' "$DISTRIBUTION_URL" | sed -E 's#.*/apache-maven/([^/]+)/.*#\1#')"
ARCHIVE_NAME="apache-maven-$MAVEN_VERSION-bin.tar.gz"
INSTALL_DIR="$BASE_DIR/.mvn/apache-maven-$MAVEN_VERSION"
ARCHIVE_PATH="${TMPDIR:-/tmp}/$ARCHIVE_NAME"
MVN_BIN="$INSTALL_DIR/bin/mvn"

if [ ! -x "$MVN_BIN" ]; then
  mkdir -p "$BASE_DIR/.mvn"

  if [ ! -f "$ARCHIVE_PATH" ]; then
    echo "Downloading Maven $MAVEN_VERSION..." >&2
    curl -fsSL "$DISTRIBUTION_URL" -o "$ARCHIVE_PATH"
  fi

  rm -rf "$INSTALL_DIR"
  mkdir -p "$INSTALL_DIR"
  tar -xzf "$ARCHIVE_PATH" -C "$INSTALL_DIR" --strip-components=1
fi

exec "$MVN_BIN" "$@"
