# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/clair_tax
SPRING_DATASOURCE_USERNAME=your_postgres_username
SPRING_DATASOURCE_PASSWORD=your_postgres_password

# Mail Configuration
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
# IMPORTANT: Gmail app passwords should NOT contain spaces
# Google displays them as "abcd efgh ijkl mnop" but you must use "abcdefghijklmnop"
# Generate app password at: https://myaccount.google.com/apppasswords
SPRING_MAIL_PASSWORD=your_app_password_without_spaces

# Optional: Flyway Configuration
# SPRING_FLYWAY_ENABLED=true

# Optional: JPA Configuration
# SPRING_JPA_SHOW_SQL=false
# SPRING_JPA_FORMAT_SQL=false
# HIBERNATE_SQL_LOG_LEVEL=INFO
